# ============================================================
# ALIAS VARIOS
# Autor: Carlos Eduardo Ocando Azuaje
# Descripción: Colección de alias para automatizar tareas
# ============================================================


# -------------------------------
# Titulo: Ejecutores y Entornos
# -------------------------------

# Comando utilizado: ng serve
# Que hace: Inicia servidor de desarrollo de Angular
alias xngs='ng serve'

alias u='cd $HOME'

# Comando utilizado: cd /usr/local/shell2/shell2/linux/shell
# Que hace: Navega al directorio del proyecto shell2
alias xshell='cd /usr/local/shell2/shell2/linux/shell'

# Comando utilizado: open
# Que hace: Abre archivos o aplicaciones en macOS
alias o='open '

# Time Machine - iniciar respaldo
alias xtm='tmutil startbackup --auto'

# Time Machine - ver estado del respaldo
alias xtms='watch tmutil status'

# Flycut - reiniciar aplicación
alias xfoff='killall Flycut && open -a Flycut && echo "Flycut reiniciado"'

# Angular - build del proyecto
alias xngb='ng build'

# Comando utilizado: speedtest --json | jq
alias xspt='speedtest --json|jq'


# Comando utilizado: mvn clean install
alias xmvni='clear && mvn clean install '

# Comando utilizado: mvn spring-boot:run
alias xmvnr='clear && mvn spring-boot:run '


# Comando utilizado: nvm i 23.0.0 && npm i express ; node -v
# Que hace: Instala Node 23 con nvm, instala express y muestra versión de Node
alias xnpm='nvm i 23.0.0 && npm i express ; node -v'

# Comando utilizado: node
# Que hace: Ejecuta Node.js
alias nno='node'


# Comando utilizado: node -v
# Que hace: Muestra versión de Node.js
alias xn3v='node -v'

# Comando utilizado: pip3 -V
# Que hace: Muestra versión de pip3
alias xp3v='pip3 -V'

# Comando utilizado: echo $PATH
# Que hace: Muestra la variable PATH
alias xph='echo "$PATH"'

# Comando utilizado: git remote -v
# Que hace: Muestra repositorios remotos de Git
alias xgr='git remote -v'

# Comando utilizado: cd /Users/carlosocando/Documents/pre_
# Que hace: Navega a carpeta pre_
alias xpre='cd /Users/carlosocando/Documents/pre_'

# Comando utilizado: java -version
# Que hace: Muestra versión de Java
alias jv='java -version'

# Comando utilizado: source ~/.zshrc
# Que hace: Recarga configuración de ZSH
alias x='source ~/.zshrc'

# Comando utilizado: cd $HOME
# Que hace: Navega al directorio HOME del usuario
alias xh='cd $HOME'

# Comando utilizado: docker
# Que hace: Ejecuta Docker
alias dk='docker '

# Comando utilizado: dotnet
# Que hace: Ejecuta .NET CLI
alias dt='dotnet '

# Comando utilizado: npm
# Que hace: Ejecuta gestor de paquetes npm
alias np='npm '

# Comando utilizado: df -ah / /Volumes
# Que hace: Muestra uso de discos principales
alias cdf='df -ah / /Volumes'

# Comando utilizado: docker system prune -a
# Que hace: Limpia contenedores, imágenes y volúmenes Docker
alias dka='docker system prune -a'

# Comando utilizado: git push
# Que hace: Envía commits al repositorio remoto
alias gps='git push '

# Comando utilizado: vagrant
# Que hace: Ejecuta comandos de Vagrant
alias vg='vagrant '

# Comando utilizado: terraform
# Que hace: Ejecuta comandos de Terraform
alias tf='terraform '

# Comando utilizado: nodemon
# Que hace: Ejecuta nodemon para reinicio automático de Node
alias ndm='nodemon'

# Comando utilizado: date +"%I:%M:%S %p"
# Que hace: Muestra hora en formato 12 horas
alias xf12="date +\"%I:%M:%S %p\""

# Comando utilizado: ls -lah
# Que hace: Lista archivos con detalles en formato humano
alias ll='ls -lah'

# Comando utilizado: cd /
# Que hace: Navega a la raíz del sistema
alias r='cd /'

# Comando utilizado: source ~/.zshrc
# Que hace: Recarga configuración ZSH
alias xs='source ~/.zshrc'


alias ..='cd ..'
alias .-='cd -'
alias pw='pwd'
